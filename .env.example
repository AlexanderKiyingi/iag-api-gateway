# Local development — set UPSTREAM_* when services run in Docker Compose.
SERVICE_NAME=api-gateway
PORT=8080
NODE_ENV=development
LOG_LEVEL=info

# Platform auth (JWT verification)
JWT_ISSUER=http://localhost:3001
JWKS_URL=http://localhost:3001/.well-known/jwks.json
JWT_AUDIENCE=iag.gateway
# Shared with upstream services (AUTH_MODE=gateway). Min 16 characters in production.
GATEWAY_INTERNAL_SECRET=dev-gateway-secret-min-16-chars

# Trusted-proxy setting for real-client-IP derivation (drives the rate limiter).
#   false (default) → trust none; behind an edge every client looks like the edge
#                     IP, so the per-IP limiter becomes ONE global bucket.
#   <N>             → trust N proxy hops (the correct, NON-spoofable choice behind
#                     a known edge). On Railway set to the edge hop count, e.g. 1.
#   true            → trust any client-supplied X-Forwarded-For (SPOOFABLE; avoid).
#   <ip,cidr,...>   → trust an explicit proxy IP/CIDR allowlist.
# PROD (Railway): set this to the edge hop count so limits key on real client IPs.
TRUST_PROXY=1

# Browser CORS (comma-separated origins). Canonical key; legacy aliases also work.
# localhost:3000 covers the Field & Farm "TraceIAG" web dashboard (Next.js) in dev.
# In production, append the deployed web origin, e.g.
#   CORS_ALLOWED_ORIGINS=https://app.iagcoffee.com,https://trace.iagcoffee.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Probe upstream /ready when handling GET /ready (Compose: true)
# READY_PROBE_UPSTREAMS=true

# Rate limits (per client IP per minute window). Requires TRUST_PROXY set to the
# edge hop count above to key on real client IPs. Store is in-memory (fine for a
# single gateway instance; a scaled gateway needs a shared/Redis store).
# RATE_LIMIT_MAX=300
# RATE_LIMIT_WINDOW_MS=60000
# OAUTH_RATE_LIMIT_MAX=30
# Tighter cap for abuse-prone auth endpoints (reset/forgot/revoke/provision/PAT mint)
# SENSITIVE_RATE_LIMIT_MAX=15

# OpenTelemetry — empty value disables OTel
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318

# Upstreams.
#
# Local dev:        127.0.0.1:<port>   (each service runs on the host)
# Docker Compose:   <service>:<port>   (Compose DNS resolves service names)
# Railway prod:     http://<service>.railway.internal:<port>
#                   ^ NOT the public *.up.railway.app URL — that hop goes via
#                     the public edge and Railway issues a 301 to the canonical
#                     hostname, leaking internal URLs through the gateway's
#                     proxy and creating a path for clients to bypass it.
#                     Internal networking is HTTP-only (no TLS inside the
#                     project), faster, and not exposed to the outside.
#                   ^ <port> is the target's ACTUAL listening port. A service
#                     that owns a public domain listens on Railway's injected
#                     $PORT, NOT its compose default — so prefer reference vars
#                     that resolve both host and port automatically:
#                       UPSTREAM_ERP=http://${{iag-erp.RAILWAY_PRIVATE_DOMAIN}}:${{iag-erp.PORT}}
#                     A wrong/unset value falls back to 127.0.0.1 below and 503s.
UPSTREAM_AUTHENTICATION=http://127.0.0.1:3001
UPSTREAM_NOTIFICATIONS=http://127.0.0.1:3002
UPSTREAM_USERS=http://127.0.0.1:3005
UPSTREAM_REPORTS=http://127.0.0.1:3003
UPSTREAM_CHAT=http://127.0.0.1:4104
# Legacy /api/v1/accounts/* accounting paths proxy to finance (same as UPSTREAM_FINANCE)
UPSTREAM_ACCOUNTS=http://127.0.0.1:3006
UPSTREAM_FINANCE=http://127.0.0.1:3006
UPSTREAM_SUPPLY_CHAIN=http://127.0.0.1:4007
UPSTREAM_FLEET=http://127.0.0.1:4008
UPSTREAM_FLEET_IOT_INGEST=http://127.0.0.1:4080
UPSTREAM_PROJECT_MANAGEMENT=http://127.0.0.1:4102
UPSTREAM_PROCUREMENT=http://127.0.0.1:4009
UPSTREAM_CONTRACT_MANAGEMENT=http://127.0.0.1:4103
UPSTREAM_CRM=http://127.0.0.1:4101
UPSTREAM_DMS=http://127.0.0.1:4010
UPSTREAM_TRACEABILITY=http://127.0.0.1:4011
UPSTREAM_TRACEAG_PORTAL=http://127.0.0.1:4020
UPSTREAM_MES=http://127.0.0.1:4003
UPSTREAM_ERP=http://127.0.0.1:4001
UPSTREAM_PRODUCTION=http://127.0.0.1:4002
UPSTREAM_QUALITY_CONTROL=http://127.0.0.1:4004
UPSTREAM_WAREHOUSE=http://127.0.0.1:4005
