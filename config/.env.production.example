SERVICE_NAME=api-gateway
PORT=8080
LOG_LEVEL=info

JWT_ISSUER=https://auth.example.com
JWKS_URL=https://auth.example.com/.well-known/jwks.json
JWT_AUDIENCE=iag.gateway
TRUST_PROXY=true
READY_PROBE_UPSTREAMS=true
NODE_ENV=production

UPSTREAM_AUTHENTICATION=http://authentication:3001
UPSTREAM_NOTIFICATIONS=http://notifications:3002
UPSTREAM_REPORTS=http://reports:3003
UPSTREAM_USERS=http://users:3005
# Legacy finance alias — same upstream as UPSTREAM_FINANCE
UPSTREAM_ACCOUNTS=http://finance:3006
UPSTREAM_FINANCE=http://finance:3006
UPSTREAM_SUPPLY_CHAIN=http://supply-chain:4007
UPSTREAM_FLEET=http://fleet:4008
UPSTREAM_FLEET_IOT_INGEST=http://fleet-iot-ingest:4080
UPSTREAM_PROJECT_MANAGEMENT=http://project-management:4102
UPSTREAM_PROCUREMENT=http://procurement:4009
UPSTREAM_CONTRACT_MANAGEMENT=http://contract-management:4103
UPSTREAM_CRM=http://crm:4101
UPSTREAM_DMS=http://dms:4010
UPSTREAM_TRACEABILITY=http://traceability:4011
UPSTREAM_MES=http://mes:4003
UPSTREAM_PRODUCTION=http://production:4002
UPSTREAM_QUALITY_CONTROL=http://quality-control:4004
UPSTREAM_WAREHOUSE=http://warehouse:4005
