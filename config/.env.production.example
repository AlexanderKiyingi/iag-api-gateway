SERVICE_NAME=api-gateway
PORT=8080
LOG_LEVEL=info

JWT_ISSUER=https://auth.example.com
JWKS_URL=https://auth.example.com/.well-known/jwks.json
GATEWAY_INTERNAL_SECRET=change-me-in-production-min-16-chars
TRUST_PROXY=true
READY_PROBE_UPSTREAMS=true
NODE_ENV=production

UPSTREAM_AUTHENTICATION=http://authentication:3001
UPSTREAM_NOTIFICATIONS=http://notifications:3002
UPSTREAM_REPORTS=http://reports:3003
UPSTREAM_ACCOUNTS=http://accounts:3005
UPSTREAM_FINANCE=http://finance:3006
UPSTREAM_SUPPLY_CHAIN=http://supply-chain:4007
UPSTREAM_FLEET=http://fleet:4008
UPSTREAM_PROJECT_MANAGEMENT=http://project-management:4102
