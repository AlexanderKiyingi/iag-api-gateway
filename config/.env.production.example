SERVICE_NAME=api-gateway
PORT=8080
LOG_LEVEL=info

JWT_ISSUER=https://auth.example.com
JWKS_URL=https://auth.example.com/.well-known/jwks.json
JWT_AUDIENCE=iag.gateway
TRUST_PROXY=true
READY_PROBE_UPSTREAMS=true
NODE_ENV=production

# --- UPSTREAM_* targets ---------------------------------------------------
# The values below use Docker-Compose service names (compose "production"
# stack). On RAILWAY the compose name/port is WRONG: a service that owns a
# public domain listens on Railway's injected $PORT (not its 4001/4005/4020
# default), so a hardcoded ":4001" is unreachable and the gateway returns 503
# UPSTREAM_ERROR. On Railway, target the private domain + the service's ACTUAL
# port via reference variables (self-correcting), e.g.:
#   UPSTREAM_ERP=http://${{iag-erp.RAILWAY_PRIVATE_DOMAIN}}:${{iag-erp.PORT}}
#   UPSTREAM_WAREHOUSE=http://${{iag-warehouse.RAILWAY_PRIVATE_DOMAIN}}:${{iag-warehouse.PORT}}
#   UPSTREAM_TRACEAG_PORTAL=http://${{iag-traceag-portal.RAILWAY_PRIVATE_DOMAIN}}:${{iag-traceag-portal.PORT}}
# (swap in the exact service names as they appear in the Railway project). Any
# UPSTREAM_* left unset falls back to 127.0.0.1:<port> — i.e. the gateway
# proxies to itself and 503s. Keep this list in sync with src/routes.ts.
UPSTREAM_AUTHENTICATION=http://authentication:3001
UPSTREAM_NOTIFICATIONS=http://notifications:3002
UPSTREAM_REPORTS=http://reports:3003
UPSTREAM_CHAT=http://chat:4104
UPSTREAM_USERS=http://users:3005
# Legacy finance alias — same upstream as UPSTREAM_FINANCE
UPSTREAM_ACCOUNTS=http://finance:3006
UPSTREAM_FINANCE=http://finance:3006
UPSTREAM_SUPPLY_CHAIN=http://supply-chain:4007
UPSTREAM_FLEET=http://fleet:4008
UPSTREAM_FLEET_IOT_INGEST=http://fleet-iot-ingest:4080
UPSTREAM_PROJECT_MANAGEMENT=http://project-management:4102
UPSTREAM_PROCUREMENT=http://procurement:4009
UPSTREAM_CONTRACT_MANAGEMENT=http://contract-management:4103
UPSTREAM_CRM=http://crm:4101
UPSTREAM_DMS=http://dms:4010
UPSTREAM_TRACEABILITY=http://traceability:4011
UPSTREAM_TRACEAG_PORTAL=http://traceag-portal:4020
UPSTREAM_ERP=http://erp:4001
UPSTREAM_MES=http://mes:4003
UPSTREAM_PRODUCTION=http://production:4002
UPSTREAM_QUALITY_CONTROL=http://quality-control:4004
UPSTREAM_WAREHOUSE=http://warehouse:4005
