{
  "name": "iag-api-gateway",
  "version": "0.1.0",
  "private": true,
  "description": "IAG platform API gateway — JWT verification, route policies, upstream proxy",
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build && tsc -p tsconfig.json",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "typecheck": "pnpm -r run typecheck && tsc -p tsconfig.json --noEmit",
    "test": "pnpm run build && node --test dist/*.test.js",
    "clean": "pnpm -r run clean && rimraf dist"
  },
  "dependencies": {
    "@iag/auth-client": "workspace:*",
    "@iag/config": "workspace:*",
    "@iag/service-core": "workspace:*",
    "@fastify/http-proxy": "^11.1.2",
    "@fastify/rate-limit": "^10.2.2",
    "fastify": "^5.2.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4"
}
